# Copy this file to .env (same folder) and paste your real token after the "=".
# Get a token in Planhat: Settings > Service Accounts (Private Apps) > API Access Token.
# Keep .env out of version control; it is already listed in .gitignore.
PLANHAT_TOKEN=paste-your-planhat-api-token-here

# Optional hardening. Uncomment to cap what any connected AI can ever do:
# PLANHAT_READ_ONLY=1        # only the list/get tools are available; nothing can be changed
# PLANHAT_DISABLE_DELETE=1   # everything except the delete tools
