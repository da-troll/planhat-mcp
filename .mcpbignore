# Ship exactly four files: manifest.json, dist/server.js (esbuild single-file
# build with all dependencies inlined), LICENSE and README.md. This is an
# allowlist: deny everything at the root, then re-include only what ships. It
# cannot be defeated by stray build artifacts, caches, secrets or new files.
/*
!/manifest.json
!/LICENSE
!/README.md
!/dist
/dist/*
!/dist/server.js
